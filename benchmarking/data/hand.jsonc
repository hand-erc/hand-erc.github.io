      "subsections": [
        {
          "title": "Finger Transparency",
          "description": "",
          "benchmarks": [
            {
              "id": "finger-breakaway-force",
              "title": "Finger Breakaway Force",
              "shortDescription": "The minimum commanded fingertip force that causes motion of the finger. A measure of static friction.",
              "description": "Breakaway force is a measure of mechanical transparency from the actuators to the fingertip that captures static friction. In the forward direction, breakaway force is the minimum commanded fingertip force that causes joint motion. This test is performed with the finger free to move unimpeded, while a slowly ramping force is commanded at the fingertip. The commanded force that causes the finger to move is recorded as the breakaway force.",
              "associatedTestbed": "<a href='benchmarks.html#component-testbeds'>Finger Testbed</a>",
              "procedures": [
                "Ensure the finger is free to move with each joint approximately flexed by 10°.",
                "Slowly ramp the commanded fingertip force (0.05 N/s) until motion is detected at the joints or fingertip."
              ],
              "collectedData": [
                "Fingertip position (X<sub>tip</sub>), or joint angles (θ)",
                "Commanded fingertip force (F<sub>tip,ref</sub>)"
              ],
              "metrics": [
                { "name": "Finger Breakaway Force", "unit": "N", "dataUsed": "X_tip or θ, F_tip,ref" }
              ],
              "analysisMethods": [""]
            },
            {
              "id": "fingertip-force-control-bandwidth",
              "title": "Fingertip Force Control Bandwidth",
              "shortDescription": "The speed with which the finger's force controller responds to control inputs.",
              "description": "Force control bandwidth describes how quickly a finger's force controller can respond to fingertip force control inputs. It is measured as the point at which the finger's closed-loop force control frequency response drops to -3dB. Force control bandwidth is measured with the fingertip in a blocked state and will vary with finger configuration due to the configuration-dependent dynamics of robot fingers.",
              "associatedTestbed": "<a href='benchmarks.html#component-testbeds'>Finger Testbed</a>",
              "procedures": [
                "Secure the fingertip to the dynamometer with the finger's joints each flexed by approximately 10°. Ensure that the dynamometer is normal to the finger pad.",
                "In force control mode, command a fingertip force sine sweep with an amplitude of 3N. The frequency range should be 0.1 Hz up to 120% of the finger's resonant frequency from the <a href='benchmark.html?id=fingertip-effective-impedance'>fingertip impedance</a> measurement.",
                "Compute the transfer function from the commanded fingertip force to the measured fingertip force and identify the frequency at which the response drops to -3dB."
              ],
              "collectedData": [
                "Internally measured fingertip force (F<sub>tip, int</sub>)",
                "Externally measured fingertip force (F<sub>tip, ext</sub>)"
              ],
              "metrics": [
                { "name": "Fingertip Force Control Bandwidth", "unit": "Hz", "dataUsed": "Commanded fingertip force and externally measured fingertip force" }
              ],
              "analysisMethods": [""]
            },
            {
              "id": "fingertip-force-tracking",
              "title": "Fingertip Force Tracking",
              "shortDescription": "Force control and sensing accuracy when tracking sinusoidal force inputs.",
              "description": "Force control accuracy is only measured in the forward direction, from the actuators to the environment. Force sensing accuracy is also measured as it can significantly impact the force control performance. This test is performed with the fingertip blocked. The finger is then commanded to produce sinusoidal force profiles at the fingertip, and the RMSE between commanded force and externally measured force is computed. For force sensing accuracy, the RMSE between the internally sensed and externally measured fingertip force is calculated.",
              "associatedTestbed": "<a href='benchmarks.html#component-testbeds'>Finger Testbed</a>",
              "procedures": [
                "Secure the fingertip to the dynamometer with the finger's joints each flexed by approximately 10°. Ensure that the dynamometer is normal to the finger pad.",
                "Command a sinusoidal fingertip force profile like the one provided by NIST, while recording the fingertip force measured by the finger sensors and by the dynamometer force sensor."
              ],
              "collectedData": [
                "Commanded fingertip force (F<sub>tip,ref</sub>)",
                "Internally measured fingertip force (F<sub>tip,int</sub>)",
                "Externally measured fingertip force (F<sub>tip, ext</sub>)"
              ],
              "metrics": [
                { "name": "Fingertip Force Control Accuracy", "unit": "N", "dataUsed": "F_tip,ext, F_tip,ref", "equation": "√(1/n Σ(F_tip,ext − F_tip,ref)²)" },
                { "name": "Fingertip Force Sensing Accuracy", "unit": "N", "dataUsed": "F_tip,ext, F_tip,int", "equation": "√(1/n Σ(F_tip,ext − F_tip,int)²)" }
              ],
              "analysisMethods": [""],
              "references": [
                "J. Falco, K. Van Wyk, and E. Messina, \"Performance Metrics and Test Methods for Robotic Hands.\" Oct. 2018. doi: <a href='https://doi.org/10.6028/NIST.SP.1227-draft'>10.6028/NIST.SP.1227-draft</a>.",
