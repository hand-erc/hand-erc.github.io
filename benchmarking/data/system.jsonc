        {
          "id": "fasten-unfasten-button",
          "title": "Fasten Button",
          "shortDescription": "Button a button on a buttoning board.",
          "description": "Button a button on a buttoning board.",
          "justification": "Fastening Button evaluates a system's ability to perform precision manipulation under tight geometric constraints involving both rigid and deformable components. The task requires quasistatic direct manipulation of a small rigid object whose dimensions are significantly smaller than those of the hand while interacting with a deformable buttonhole. The task exhibits high constraint complexity, as successful completion depends on satisfying multiple geometric constraints simultaneously while maintaining stable contact with the button and fabric. It also involves substantial constraint change, progressing from free-space manipulation to contact with the buttonhole, partial insertion, and eventual passage through the fabric. The interaction requires careful coordination of fingertip forces and object pose throughout the manipulation sequence, and small positioning errors can lead to task failure. More broadly, button fastening serves as a representative benchmark for fine manipulation tasks encountered in dressing, garment handling, and other activities that require precise interaction with small everyday objects.",
          "items": [
            {
              "item": "Buttoning board",
              "quantity": 1,
              "specification": "Buttoning board",
              "link": "https://example.com/buttoning-board"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Place the buttoning board near the center of the table.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the buttoning board and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Approach and grasp the button.",
            "Pull the button completely through the opening until it reaches the fully fastened configuration.",
            "Release the button.",
            "A trial is considered successful if the button remains fully fastened after the manipulator releases contact and no portion of the button remains trapped within the buttonhole."
          ],
          "metrics": [
