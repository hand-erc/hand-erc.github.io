{
  "description": ["System-Level dexterity benchmarks require high-level integration of the hands with robot arms, vision, control, AI,",
          " possibly teleoperation, and more to complete short-horizon 'atomic' tasks. These atomic tasks were selected to test different", 
          " features of dexterity, emphasizing in-hand manipulation."],
  "sections": [
    {
      "title": "Atomic Benchmarking Tasks",
      "description": "Benchmarks covering a broad range of dexterous abilities.",
      "benchmarks": [
        {
          "id": "box-and-blocks",
          "title": "Box and Blocks",
          "shortDescription": "Transfer as many blocks as possible from a cluttered bin to another bin within 60 seconds.",
          "description": "Starting with blocks in an initial bin, transfer as many blocks as possible over a divider into an adjacent target bin within 60 seconds.",
          "justification": "Box and Blocks evaluates a system’s ability to isolate, grasp, and transport objects from a cluttered environment to a designated target location under time constraints. Although the task involves quasistatic direct manipulation of simple rigid objects with low constraint complexity, high performance still requires reliable grasp acquisition, grasp stability, and efficient object handling, all of which benefit from increased dexterity. Furthermore, object transport serves as a fundamental building block for many more complex manipulation behaviors, which can often be decomposed into sequences of grasp-and-transport actions.",
          "items": [
            {
              "item": "Bins",
              "quantity": 2,
              "specification": "YCB #69",
              "link": "https://example.com/bins"
            },
            {
              "item": "Lid",
              "quantity": 1,
              "specification": "YCB #70",
              "link": "https://example.com/lid"
            },
            {
              "item": "Blocks",
              "quantity": 100,
              "specification": "YCB #71",
              "link": "https://example.com/blocks"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Arrange items according to the setup diagram shown in the YCB Box and Blocks protocol.",
            "Randomly distribute the blocks in the initial bin."
          ],
          "procedures": [
            "Setup environment as described above.",
            "During a 60-second time period, transfer as many blocks as possible from one bin to another."
          ],
          "metrics": [
            {
              "name": "Number of Blocks Transferred",
              "unit": "blocks",
              "description": "Number of blocks transferred into the target bin."
            },
            {
              "name": "Success Rate",
              "unit": "ratio",
              "description": "Number of blocks transferred divided by the number of attempts. An attempt is defined as any time the end effector makes contact with a block in the starting bin and the bottom of the end effector reaches a height equal to the height of the bin."
            }
          ],
          "analysisMethods": [
            "Vary block size.",
            "Vary total number of blocks.",
            "Vary bin dimensions."
          ]
        },
        {
          "id": "peg-in-hole",
          "title": "Peg-in-Hole",
          "shortDescription": "Insert pegs into a pegboard with holes of various shapes and tolerances.",
          "description": "Insert pegs into the NIST Assembly Task Board M1 with holes of various shapes and tolerances.",
          "justification": "Peg-in-Hole evaluates a system's ability to perform precision assembly under tight geometric tolerances. The task involves quasistatic direct manipulation of a rigid object whose size is comparable to that of the hand. The task exhibits high constraint complexity, since successful completion depends on satisfying multiple geometric constraints simultaneously while operating within narrow positional and angular tolerances. It also features significant constraint change, as the interaction progresses from unconstrained free-space motion to increasingly restrictive contact conditions as the peg enters the hole. More broadly, peg insertion serves as a canonical example of contact-rich assembly and is representative of a wide range of industrial manufacturing operations.",
          "items": [
            {
              "item": "NIST Assembly Task Board M1",
              "quantity": 1,
              "specification": "NIST Assembly Task Board M1",
              "link": "https://example.com/nist-assembly-task-board-m1"
            },
            {
              "item": "Corresponding Pegs",
              "quantity": 1,
              "specification": "Corresponding Pegs",
              "link": "https://example.com/corresponding-pegs"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Refer to the ManipulationNet website for the standardized setup."
          ],
          "procedures": [
            "Place the pegs and pegboard in standardized starting positions.",
            "Grasp a peg.",
            "Align the peg with the target hole.",
            "Insert the peg fully into the hole.",
            "Repeat for all specified peg-hole pairs."
          ],
          "metrics": [
            {
              "name": "Pegs Inserted",
              "unit": "pegs",
              "description": "Number of pegs successfully inserted."
            },
            {
              "name": "Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            }
          ],
          "analysisMethods": [
            "Vary peg dimensions.",
            "Vary hole tolerances.",
            "Vary number of pegs and holes.",
            "Vary material properties."
          ]
        },
        {
          "id": "pick-up-flat-object",
          "title": "Pick Up Flat Object",
          "shortDescription": "Stably grasp an M6 washer initially lying flat on a rigid table.",
          "description": "Stably grasp an M6 washer initially lying flat on a rigid table.",
          "justification": "Pick Up Flat Object evaluates a system's ability to acquire and maintain a stable grasp on a thin object resting on a supporting surface. The task involves quasistatic direct manipulation of a rigid object whose dimensions are substantially smaller than those of the hand, requiring precise fingertip placement and careful coordination during grasp acquisition. Unlike many object relocation tasks, the supporting surface significantly restricts access to the object, increasing constraint complexity by limiting feasible contact locations and grasp approaches. Successful completion often requires managing changing contact conditions as the object transitions from table contact to hand support, introducing moderate constraint change throughout the grasping process. More broadly, grasping thin objects is representative of many real-world manipulation scenarios involving washers, coins, cards, sheets, and other low-profile objects that are challenging to isolate from supporting surfaces.",
          "items": [
            {
              "item": "M6 washer",
              "quantity": 1,
              "specification": "M6 washer",
              "link": "https://example.com/m6-washer"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Place the washer flat on the tabletop near the center of the table.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the washer and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Approach the washer and establish a stable grasp without moving the washer outside the workspace.",
            "Lift the washer to a height of at least 2 cm above the tabletop.",
            "Maintain control of the washer for a minimum of 3 seconds while keeping it stationary and above the required height.",
            "A trial is considered successful if the washer is lifted to the required height, remains under control throughout transport, and comes to rest within the target region without being dropped."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            },
            {
              "name": "Success Rate",
              "unit": "ratio",
              "description": "Number of successful trials divided by the number of attempted grasps."
            }
          ],
          "analysisMethods": [
            "Vary washer dimensions.",
            "Vary washer material properties.",
            "Vary table surface properties."
          ]
        },
        {
          "id": "tie-a-knot",
          "title": "Tie a Knot",
          "shortDescription": "Tie a string into a tight overhand knot.",
          "description": "Tie a string into a tight overhand knot.",
          "justification": "Tying a Knot evaluates a system's ability to manipulate deformable objects whose geometry changes continuously throughout the task. The task involves direct manipulation of a flexible string whose dimensions are small relative to the hand and whose effective number of controllable degrees of freedom is substantially greater than that of rigid objects. Unlike rigid-body manipulation tasks, successful completion requires coordinating a sequence of intermediate configurations while controlling both the global shape and local contacts of the string. The task exhibits high constraint complexity, as knot formation requires creating and maintaining loops, passing one portion of the string through another, and satisfying topological constraints that do not arise in conventional assembly tasks. It also involves substantial constraint change, with contacts between the string, hand, and environment being repeatedly established, broken, and reconfigured throughout the manipulation. While the task is primarily quasistatic, successful execution demands long-horizon planning, precise contact management, and adaptation to continuously changing object geometry. More broadly, knot tying serves as a representative benchmark for deformable-object manipulation and captures many of the challenges encountered when handling ropes, cables, sutures, and other flexible materials.",
          "items": [
            {
              "item": "String",
              "quantity": 1,
              "specification": "500 mm length, 5 mm diameter braided cotton cord",
              "link": "https://example.com/string"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Place the string flat on the tabletop in a straight configuration with no self-intersections.",
            "The midpoint of the string should be located near the center of the table, and both endpoints should be fully visible and accessible.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the string and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Grasp and manipulate the string to form a single loop.",
            "Pass one end of the string through the loop to create an overhand knot.",
            "Tighten the knot by pulling on the free ends until no visible slack remains in the knot structure.",
            "Release the string.",
            "A trial is considered successful if a valid overhand knot has been formed and remains intact after release, with no visible slack remaining in the knot."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            },
            {
              "name": "Success Rate",
              "unit": "ratio",
              "description": "Number of successful knots divided by the number of trials."
            }
          ],
          "analysisMethods": [
            "Vary rope dimensions.",
            "Vary rope material properties.",
            "Vary knot complexity."
          ]
        },
        {
          "id": "twist-lid-on-jar",
          "title": "Twist Lid on Jar",
          "shortDescription": "Pick up a regular mouth Mason jar lid from a table and thread and tighten it onto a fixed jar.",
          "description": "Pick up a regular mouth Mason jar lid from a table and thread and tighten it onto a fixed jar.",
          "justification": "Twisting a Lid on a Jar evaluates a system's ability to perform contact-rich assembly involving both translational and rotational manipulation. The task involves quasistatic direct manipulation of a rigid object whose dimensions are comparable to those of the hand and requires sequentially coordinating object relocation, alignment, and in-hand manipulation. The task exhibits substantial constraint complexity, since successful completion depends on satisfying geometric constraints imposed by the threaded interface while simultaneously maintaining a stable grasp and applying sufficient torque. It also involves significant constraint change, as the interaction progresses from unconstrained free-space motion to initial contact, thread engagement, and eventually fully constrained rotational tightening. More broadly, lid threading is representative of a wide range of household and industrial assembly operations that require alignment, insertion, and controlled application of rotational forces.",
          "items": [
            {
              "item": "Regular-mouth Mason jar lid",
              "quantity": 1,
              "specification": "Regular-mouth Mason jar lid",
              "link": "https://example.com/regular-mouth-mason-jar-lid"
            },
            {
              "item": "Regular-mouth Mason jar",
              "quantity": 1,
              "specification": "Regular-mouth Mason jar",
              "link": "https://example.com/regular-mouth-mason-jar"
            },
            {
              "item": "Rigid mounting fixture",
              "quantity": 1,
              "specification": "Rigid mounting fixture",
              "link": "https://example.com/rigid-mounting-fixture"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Secure the Mason jar vertically to the table using the mounting fixture such that the jar cannot translate or rotate during the task.",
            "Place the lid flat on the tabletop with its open side facing downward and its center approximately 150 mm from the centerline of the jar.",
            "Randomize the lid's orientation about the vertical axis prior to each trial.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the lid and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Approach and establish a stable grasp on the lid.",
            "Lift the lid from the table and transport it to the jar.",
            "Align the lid with the threaded opening of the jar.",
            "Engage the threads and rotate the lid until it is fully seated on the jar.",
            "Release the lid.",
            "A trial is considered successful if the lid is properly threaded onto the jar, fully seated, and remains attached to the jar after the manipulator releases contact."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            },
            {
              "name": "Success Rate",
              "unit": "ratio",
              "description": "Number of successful assemblies divided by the number of trials."
            }
          ],
          "analysisMethods": [
            "Vary lid and jar dimensions.",
            "Vary tightening torque.",
            "Vary cap type."
          ]
        },
        {
          "id": "thread-screw-with-screwdriver",
          "title": "Use Screwdriver",
          "shortDescription": "Beginning with a threaded screw, pick up and use a screwdriver to tighten the screw.",
          "description": "Beginning with a threaded screw, pick up and use a screwdriver to tighten the screw.",
          "justification": "Use Screwdriver evaluates a system's ability to perform quasistatic indirect manipulation of a rigid object through the use of a tool. Relative to direct assembly tasks, screwdriver use introduces additional degrees of freedom associated with grasping, orienting, and stabilizing the tool while simultaneously controlling its interaction with the screw. The task exhibits high constraint complexity, as successful completion requires maintaining alignment between the screwdriver tip and screw head, generating sufficient torque to advance the screw, and regulating contact forces to prevent the driver head from camming out. It also involves substantial constraint change, progressing from free-space tool transport to tool engagement, threaded insertion, and final tightening. More broadly, screwdriver use serves as a representative benchmark for tool use and indirect manipulation, capabilities that are fundamental to many manufacturing, maintenance, and assembly operations.",
          "items": [
            {
              "item": "Phillips-head screwdriver",
              "quantity": 1,
              "specification": "Phillips-head screwdriver",
              "link": "https://example.com/phillips-head-screwdriver"
            },
            {
              "item": "Phillips-head screw",
              "quantity": 1,
              "specification": "Phillips-head screw",
              "link": "https://example.com/phillips-head-screw"
            },
            {
              "item": "Rigid mounting block with threaded hole",
              "quantity": 1,
              "specification": "Rigid mounting block with threaded hole",
              "link": "https://example.com/rigid-mounting-block-with-threaded-hole"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Secure the mounting block to the table such that it cannot translate or rotate during the task.",
            "Insert the screw into the threaded hole until approximately half of the screw length remains exposed above the mounting surface.",
            "Place the screwdriver flat on the tabletop approximately 150 mm from the mounting block.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from both the screwdriver and screw and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Approach and establish a stable grasp on the screwdriver.",
            "Align the screwdriver tip with the screw head and engage the screw.",
            "Rotate the screwdriver to advance the screw into the threaded hole.",
            "Continue tightening until the underside of the screw head makes contact with the mounting surface and no visible gap remains.",
            "Disengage the screwdriver from the screw.",
            "A trial is considered successful if the screw is fully seated in the threaded hole and remains tightened after the manipulator releases contact."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            },
            {
              "name": "Success Rate",
              "unit": "ratio",
              "description": "Number of successful insertions divided by the number of trials."
            }
          ],
          "analysisMethods": [
            "Vary screwdriver size.",
            "Vary screw and hole dimensions.",
            "Vary tightening torque."
          ]
        },
        {
          "id": "cut-pattern-with-scissors",
          "title": "Use Scissors",
          "shortDescription": "Pick up and use scissors to cut out a circle drawn on a piece of paper.",
          "description": "Pick up and use scissors to cut out a circle drawn on a piece of paper.",
          "justification": "Use Scissors evaluates a system's ability to perform indirect quasistatic manipulation through an articulated tool while interacting with a deformable object. The task requires manipulating a pair of scissors whose dimensions are comparable to those of the hand while simultaneously controlling the motion and deformation of a sheet of paper. Relative to direct manipulation tasks, scissor use introduces additional degrees of freedom associated with the tool's articulation and coordination between the tool and the material being cut. The task exhibits substantial constraint complexity, as successful completion requires maintaining proper blade alignment, generating sufficient cutting forces, and accurately following a prescribed cutting trajectory. More broadly, scissor use serves as a representative benchmark for articulated tool manipulation and tool-mediated interaction with deformable objects, capabilities that are important in manufacturing, medical, and household manipulation tasks.",
          "items": [
