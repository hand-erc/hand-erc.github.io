        {
          "id": "spin-a-top",
          "title": "Spin a Top",
          "shortDescription": "Spin a top so that it remains upright.",
          "description": "Spin a top so that it remains upright.",
          "justification": "Spinning a Top evaluates a system's ability to exploit object dynamics to achieve a desired outcome. The task involves dynamic direct manipulation of a rigid object whose dimensions are small relative to the hand and requires generating an appropriate combination of orientation, angular velocity, and release conditions for successful execution. Unlike many dexterous manipulation tasks that are primarily quasistatic, spinning a top depends critically on dynamic interactions and the transfer of momentum from the hand to the object. The task exhibits moderate constraint complexity, as successful performance requires coordinating grasping, rotational motion, and release timing while maintaining control of the object up to the point of disengagement. It also involves significant constraint change, progressing from stable grasping to dynamic release, after which the object's behavior is governed entirely by its interaction with the environment. Because the top's stability depends on the quality of the imparted spin, small errors in orientation, velocity, or release timing can lead to immediate failure. More broadly, spinning a top serves as a representative benchmark for dynamic dexterous manipulation, evaluating a manipulator's ability to intentionally exploit physical dynamics rather than relying solely on precise quasistatic control.",
          "items": [
            {
              "item": "Top",
              "quantity": 1,
              "specification": "Top",
              "link": "https://example.com/top"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface",
              "link": "https://example.com/rigid-table"
            }
          ],
          "setup": [
            "Place the top upright near the center of the table.",
            "The top shall initially be stationary and in stable contact with the table surface.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the top and 100 mm above the table surface."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Approach and establish a stable grasp on the top.",
            "Impart rotational velocity to the top and release it onto the table surface.",
            "Allow the top to spin freely without further contact from the manipulator.",
            "A trial is considered successful if the top remains upright and spinning for at least 5 seconds following release."
          ],
          "metrics": [
            {
              "name": "Spin Duration",
              "unit": "seconds",
              "description": "Time between release and first contact of the top body with the table surface."
            }
          ],
          "analysisMethods": [
            "Vary top dimensions.",
            "Vary top mass distribution.",
            "Vary table surface properties."
          ]
        },
        {
          "id": "use-chopsticks",
          "title": "Use Chopsticks",
          "shortDescription": "Use chopsticks to pick up small wooden cubes and place them in a bin.",
          "description": "Use chopsticks to pick up small wooden cubes and place them in a bin.",
          "justification": "Use Chopsticks evaluates a system's ability to perform quasistatic indirect manipulation through a pair of tools while handling small objects that are significantly smaller than the hand. The task involves manipulating two rigid chopsticks and a set of rigid cubes, requiring coordinated control of multiple objects simultaneously. Relative to direct grasping tasks, the use of chopsticks introduces additional degrees of freedom associated with controlling the relative motion and contact forces between the chopsticks while maintaining stable object capture. The task exhibits substantial constraint complexity, as successful completion requires precise alignment of the chopsticks, careful force regulation to prevent dropping or crushing the object, and accurate placement of the object into a target container. It also involves repeated constraint change, progressing through cycles of tool positioning, object acquisition, object transport, and object release. More broadly, chopstick use serves as a representative benchmark for precision tool use and indirect manipulation, assessing a manipulator's ability to perform fine object handling through intermediate tools rather than direct hand-object contact.",
          "items": [
            {
              "item": "Chopsticks",
