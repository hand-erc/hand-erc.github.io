{
  "description": [
    "System-Level dexterity benchmarks require high-level integration of the hands with robot arms, vision, control, AI,",
    " possibly teleoperation, and more to complete short-horizon 'atomic' tasks. These atomic tasks were selected to test different",
    " features of dexterity, emphasizing in-hand manipulation."
  ],
  "sections": [
    {
      "title": "Atomic Benchmarking Tasks",
      "description": "Benchmarks covering a broad range of dexterous abilities.",
      "benchmarks": [
        {
          "id": "box-and-blocks",
          "title": "Box and Blocks",
          "shortDescription": "Transfer as many blocks as possible from a cluttered bin to another bin within 60 seconds.",
          "description": "Starting with blocks in an initial bin, transfer as many blocks as possible over a divider into an adjacent target bin within 60 seconds. This task's setup and procedure are equivalent to Protocol 3a of the YCB Box and Blocks benchmark. Further details on the setup and procedure can be found here.",
          "justification": "Box and Blocks evaluates a system's ability to isolate, grasp, and transport objects from a cluttered environment to a designated target location under time constraints. Although the task involves quasistatic direct manipulation of simple rigid objects with low constraint complexity, high performance still requires reliable grasp acquisition, grasp stability, and efficient object handling, all of which benefit from increased dexterity. Furthermore, object transport serves as a fundamental building block for many more complex manipulation behaviors, which can often be decomposed into sequences of grasp-and-transport actions.",
          "items": [
            {
              "item": "Bins",
              "quantity": 2,
              "specification": "YCB #69",
              "link": "https://www.ycbbenchmarks.com/object-set/"
            },
            {
              "item": "Lid",
              "quantity": 1,
              "specification": "YCB #70",
              "link": "https://www.ycbbenchmarks.com/object-set/"
            },
            {
              "item": "Blocks",
              "quantity": 100,
              "specification": "YCB #71",
              "link": "https://www.ycbbenchmarks.com/object-set/"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface capable of holding manipulanda.",
              "link": "https://www.uline.com/Product/Detail/H-6979/Steel-Workbenches/Adjustable-Height-Machine-Table-24-x-18-x-18-25?pricode=WB6636&gadtype=pla&id=H-6979&ad_group_id=150516799157&gad_source=1&gad_campaignid=11612151768&gclid=EAIaIQobChMI2vHI1pKmlQMV_SbUAR01bglwEAQYASABEgLPJvD_BwE"
            }
          ],
          "setup": [
            "Arrange items according to the setup diagram shown in the YCB Box and Blocks protocol.",
            "Randomly distribute the blocks in the initial bin.",
            "The manipulation system's end effector must start outside of both bins."
          ],
          "procedures": [
            "Setup environment as described above.",
            "During a 60 second time period, transfer as many blocks as possible from one bin to another."
          ],
          "metrics": [
            {
              "name": "Number of Blocks Transferred",
              "unit": "blocks",
              "description": "Number of blocks transferred into the target bin."
            }
          ],
          "executionConstraints": [
            "For a successful transfer, a blcok must cross over the deviding barrier before being dropped. BLocks cannot be tossed over the barrier.",
            "If multiple blocks are tranported at the same time, it is counted as one block."
          ],
          "protocolLink": "https://www.ycbbenchmarks.com/protocols-and-benchmarks/"
        },
        {
          "id": "peg-in-hole",
          "title": "Peg-in-Hole",
          "shortDescription": "Insert pegs into a pegboard with holes of various shapes and tolerances.",
          "description": "Insert pegs into the NIST Assembly Task Board M1 with holes of various shapes and tolerances. This task's setup and procedure are equivalent to a single round of ManipulationNet's peg insertion task. Further details on the setup and procedure can be found here.",
          "justification": "Peg-in-Hole evaluates a system's ability to perform precision assembly under tight geometric tolerances. The task involves quasistatic direct manipulation of a rigid object whose size is comparable to that of the hand. The task exhibits high constraint complexity, since successful completion depends on satisfying multiple geometric constraints simultaneously while operating within narrow positional and angular tolerances. It also features significant constraint change, as the interaction progresses from unconstrained free-space motion to increasingly restrictive contact conditions as the peg enters the hole. More broadly, peg insertion serves as a canonical example of contact-rich assembly and is representative of a wide range of industrial manufacturing operations.",
          "items": [
            {
              "item": "NIST Assembly Task Board M1",
              "quantity": 1,
              "specification": "NIST Assembly Task Board M1",
              "link": "https://manipulation-net.org/tasks/peg_in_hole.html"
            },
            {
              "item": "Pegs",
              "quantity": 5,
              "specification": "Corresponding circle, hexagon, triangle, rectangle and L-shape pegs",
              "link": "https://manipulation-net.org/tasks/peg_in_hole.html"
            },
            {
              "item": "Peg Holder",
              "quantity": 1,
              "specification": "Corresponding Peg-holder",
              "link": "https://manipulation-net.org/tasks/peg_in_hole.html"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface capable of holding manipulanda.",
              "link": "https://www.uline.com/Product/Detail/H-6979/Steel-Workbenches/Adjustable-Height-Machine-Table-24-x-18-x-18-25?pricode=WB6636&gadtype=pla&id=H-6979&ad_group_id=150516799157&gad_source=1&gad_campaignid=11612151768&gclid=EAIaIQobChMI2vHI1pKmlQMV_SbUAR01bglwEAQYASABEgLPJvD_BwE"
            }
          ],
          "setup": [
            "Place both the assembly task board and peg holder on the table in any preferred configuration."
          ],
          "procedures": [
            "Place the pegs and pegboard in the perscribed starting positions and select a row n from the pegboard rows numbered 1 through 4 to fill.",
            "Grasp peg of shape corresponding to target hole.",
            "Align and insert the peg into the target hole.",
            "Repeat for all five peg-hole pairs. The order of insertion is A(n),B(n),C(n),D(n),E(n)."
          ],
          "metrics": [
            {
              "name": "Pegs Inserted",
              "unit": "pegs",
              "description": "Number of pegs successfully inserted."
            }
          ],
          "executionConstraints": [
            "Any strategy may be used to accomplish this task.",
            "The manipulation system has three hours to complete the task."
          ],
          "protocolLink": "https://manipulation-net.org/tasks/peg_in_hole.html"
        },
        {
          "id": "pick-up-flat-object",
          "title": "Pick Up Flat Object",
          "shortDescription": "Stably grasp an M6 washer initially lying flat on a rigid table.",
          "description": "Grasp and lift an M6 washer initially resting flat on a rigid tabletop to a specified height without dropping it.",
          "justification": "Pick Up Flat Object evaluates a system's ability to acquire and maintain a stable grasp on a thin object resting on a supporting surface. The task involves quasistatic direct manipulation of a rigid object whose dimensions are substantially smaller than those of the hand, requiring precise fingertip placement and careful coordination during grasp acquisition. Unlike many object relocation tasks, the supporting surface significantly restricts access to the object, increasing constraint complexity by limiting feasible contact locations and grasp approaches. Successful completion often requires managing changing contact conditions as the object transitions from table contact to hand support, introducing moderate constraint change throughout the grasping process. More broadly, grasping thin objects is representative of many real-world manipulation scenarios involving washers, coins, cards, sheets, and other low-profile objects that are challenging to isolate from supporting surfaces.",
          "items": [
            {
              "item": "M6 washer",
              "quantity": 1,
              "specification": "Stainless Steel M6 Washer.",
              "link": "https://www.mcmaster.com/91701A621/"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface capable of holding manipulanda.",
              "link": "https://www.uline.com/Product/Detail/H-6979/Steel-Workbenches/Adjustable-Height-Machine-Table-24-x-18-x-18-25?pricode=WB6636&gadtype=pla&id=H-6979&ad_group_id=150516799157&gad_source=1&gad_campaignid=11612151768&gclid=EAIaIQobChMI2vHI1pKmlQMV_SbUAR01bglwEAQYASABEgLPJvD_BwE"
            }
          ],
          "setup": [
            "Place the washer flat on the tabletop near the center of the table.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from the washer."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Transport the washer to a height of at least 2 cm above the tabletop.",
            "Maintain control of the washer for a minimum of 3 seconds while keeping it stationary and above the required height.",
            "A trial is considered successful if the washer is lifted to the required height, and comes to rest within the target region for the alloted time."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            }
          ],
          "executionConstraints": [
            "Any method can be used to grasp, lift, and hold the washer at the desired height.",
            "The manipulation system has 60 seconds to complete the task."
          ]
        },
        {
          "id": "tie-a-knot",
          "title": "Tie a Knot",
          "shortDescription": "Tie a rope into a tight overhand knot.",
          "description": "Tie a rope into a tight overhand knot.",
          "justification": "Tie a Knot evaluates a system's ability to manipulate deformable objects whose geometry changes continuously throughout the task. The task involves direct manipulation of a flexible rope with some dimensions that are small relative to the hand and whose effective number of controllable degrees of freedom is substantially greater than that of rigid objects. Unlike rigid-body manipulation tasks, successful completion requires coordinating a sequence of intermediate configurations while controlling both the global shape and local contacts of the string. In addition, knot formation requires satisfying topological constraints that do not arise in conventional assembly tasks. While the task is primarily quasistatic, successful execution demands precise contact management, and adaptation to continuously changing object geometry. More broadly, knot tying serves as a representative benchmark for deformable-object manipulation and captures many of the challenges encountered when handling ropes, cables, sutures, and other flexible materials.",
          "items": [
            {
              "item": "rope",
              "quantity": 1,
              "specification": "50 cm long 1/4 in diameter low stretch polyester plastic rope.",
              "link": "https://www.mcmaster.com/3132T131/"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface capable of holding manipulanda.",
              "link": "https://www.uline.com/Product/Detail/H-6979/Steel-Workbenches/Adjustable-Height-Machine-Table-24-x-18-x-18-25?pricode=WB6636&gadtype=pla&id=H-6979&ad_group_id=150516799157&gad_source=1&gad_campaignid=11612151768&gclid=EAIaIQobChMI2vHI1pKmlQMV_SbUAR01bglwEAQYASABEgLPJvD_BwE"
            }
          ],
          "setup": [
            "Place the rope near the center of the table in any configuration such that the rope does not self intersect.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from all of the manipulanda."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Manipulate the rope to tie and overhand knot.",
            "Release the tied rope onto the table.",
            "A trial is considered successful if a valid overhand knot has been formed which remains intact after release, with no visible slack remaining in the knot."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            }
          ],
          "executionConstraints": [
            "Any stategy can be used to accomplish the task.",
            "The manipulation system has 60 seconds to complete the task."
          ]
        },
        {
          "id": "twist-lid-on-jar",
          "title": "Twist Lid on Jar",
          "shortDescription": "Pick up a regular mouth round jar lid from a table and thread and tighten it onto a fixed jar.",
          "description": "Pick up a regular mouth round jar lid from a table and thread and tighten it onto a fixed jar.",
          "justification": "Twist a Lid on Jar evaluates a system's ability to perform contact-rich assembly involving both translational and rotational manipulation. The task involves quasistatic direct manipulation of a rigid object whose dimensions are comparable to those of the hand and requires sequentially coordinating object relocation, alignment, and in-hand manipulation. The task exhibits substantial constraint complexity, since successful completion depends on satisfying geometric constraints imposed by the threaded interface while simultaneously maintaining a stable grasp and applying sufficient torque. It also involves significant constraint change, as the interaction progresses from unconstrained free-space motion to initial contact, thread engagement, and eventually fully constrained rotational tightening. More broadly, lid threading is representative of a wide range of household and industrial assembly operations that require alignment, insertion, and controlled application of rotational forces.",
          "items": [
            {
              "item": "jar lid",
              "quantity": 1,
              "specification": "89-400 regular-mouth round plastic jar lid",
              "link": "https://www.uline.com/Product/Detail/S-9936/Jars/Clear-Round-Wide-Mouth-Plastic-Jars-16-oz-White-Cap?pricode=WB0644&gadtype=pla&id=S-9936&ad_group_id=152179486982&gad_source=1&gad_campaignid=11612151543&gclid=Cj0KCQjwguLSBhDLARIsAH-yPrELFzXivNndELEB9E2T3k6Yjjk5g-u3pHuzmfw575vte0hAn15mJ2IaArQNEALw_wcB"
            },
            {
              "item": "Regular-mouth jar",
              "quantity": 1,
