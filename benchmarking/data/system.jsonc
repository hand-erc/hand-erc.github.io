              "specification": "10-32 steel panhead Phillips-head machine screw",
              "link": "https://www.mcmaster.com/92224A202/"
            },
            {
              "item": "Rigid mounting block with threaded hole",
              "quantity": 1,
              "specification": "Rigid mounting block with 10-32 threaded hole. (e.g., screw mount nut attached to 3D printed block)",
              "link": "https://www.mcmaster.com/90611A340/"
            },
            {
              "item": "Rigid Table",
              "quantity": 1,
              "specification": "Flat rigid work surface capable of holding manipulanda.",
              "link": "https://www.uline.com/Product/Detail/H-6979/Steel-Workbenches/Adjustable-Height-Machine-Table-24-x-18-x-18-25?pricode=WB6636&gadtype=pla&id=H-6979&ad_group_id=150516799157&gad_source=1&gad_campaignid=11612151768&gclid=EAIaIQobChMI2vHI1pKmlQMV_SbUAR01bglwEAQYASABEgLPJvD_BwE"
            }
          ],
          "setup": [
            "Secure the mounting block to the table such that it cannot translate or rotate during the task.",
            "Insert the screw into the threaded hole and thread one complete revolution into the hole.",
            "Place the screwdriver flat on the tabletop approximately 150 mm from the mounting block.",
            "The manipulator shall begin each trial with the nearest point on the end effector at least 100 mm away from all of the manipulanda."
          ],
          "procedures": [
            "Position the manipulator in the prescribed starting configuration.",
            "Grasp the screwdriver and use it to thread the screw three rotations into the threaded hole.",
            "Disengage the screwdriver from the screw.",
            "A trial is considered successful if the screw is has been threaded a total of at least four rotations into the threaded hole."
          ],
          "metrics": [
            {
              "name": "Total Task Completion Time",
              "unit": "seconds",
              "description": "Time required to complete the task."
            }
          ],
          "executionConstraints": [
            "Any stategy can be used as long as the manipulator never contacts the screw.",
            "The manipulation system has 60 seconds to complete the task."
          ]
